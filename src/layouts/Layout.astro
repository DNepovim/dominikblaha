---
import Analytics from "@vercel/analytics/astro";
import "@/styles/global.css";
import { UMAMI_SITE_ID } from "astro:env/client";
import type { MarkdownLayoutProps } from "astro";

interface Frontmatter {
  title: string;
  description: string;
}

type Props = MarkdownLayoutProps<Frontmatter>;

const {
  frontmatter: { title, description },
} = Astro.props;

const config = {
  url: "https://cloud.umami.is/script.js",
  websiteId: UMAMI_SITE_ID,
} as const;
---

<!doctype html>
<html lang="cs" class="font-text">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="color-scheme" content="light dark" />
    <script is:inline defer src={config.url} data-website-id={config.websiteId}
    ></script>
  </head>
  <body>
    <Analytics />
    <main>
      <slot />
    </main>
    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        window.addEventListener(
          "keydown",
          function (e) {
            if (e.key === "2" && window.location.pathname === "/") {
              e.preventDefault();
              e.stopPropagation();
              window.location.href = window.location.origin + "/en";
            } else if (e.key === "1" && window.location.pathname === "/en") {
              e.preventDefault();
              e.stopPropagation();
              window.location.href = window.location.origin + "/";
            }
          },
          true,
        );
      });
    </script>
  </body>
</html>
